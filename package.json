{
    "name": "task-family",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev": "concurrently -n app,tunnel -c blue,magenta \"turbo run dev\" \"npx localtunnel --port 5173 --subdomain taskfamily-dev\"",
        "build": "turbo run build",
        "start": "turbo run start",
        "lint": "turbo run lint",
        "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json}\"",
        "db:up": "docker-compose up -d",
        "db:down": "docker-compose down",
        "db:logs": "docker-compose logs -f"
        
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "eslint": "^8.45.0",
        "prettier": "^3.0.0",
        "turbo": "^1.10.0"
    },
    "engines": {
        "node": ">=18"
    }
}
