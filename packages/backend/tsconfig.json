{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022"],
        "module": "commonjs",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "outDir": "dist",
        "rootDir": "src",
        "types": ["node"],
        "baseUrl": ".",
        "paths": {
            "@task-family/shared": [
                "../../node_modules/@task-family/shared",
                "../shared"
            ]
        }
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"]
}
